{
  "include": ["./src/**/*.js"],
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "module": "commonjs",
    "target": "ESnext",
    "allowJs": true,
    "checkJs": false,
    "types": [],
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  }
}
